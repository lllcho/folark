# ── folark 配置 ──────────────────────────────────────────
# 复制此文件为 .env 并按需修改：
#   cp .env.example .env

# 服务端口（默认 8000）
# PORT=8890

# 登录密码（留空则不启用认证）
# AUTH_PASSWORD=your_password_here

# 数据存储根目录（容器内路径，默认 ./data）
# DATA_ROOT=./data

# 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=DEBUG

# 单次上传最大大小（字节，默认 500MB）
# MAX_UPLOAD_SIZE=524288000
