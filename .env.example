# ── folark 配置 ──────────────────────────────────────────
# 复制此文件为 .env 并按需修改：
#   cp .env.example .env
#
# 所有配置项都可通过环境变量设置。
# Docker 部署时也可通过 docker-compose.yml 的 environment 字段传入。

# 服务端口（默认 8890）
# PORT=8890

# 登录密码（留空则不启用认证）
# 设置后访问 folark 需要先输入此密码登录
# AUTH_PASSWORD=your_password_here

# 数据存储根目录（默认 ./data）
# 所有数据（文档库、数据库、日志）都保存在此目录下
# 注意：Docker 部署时此路径是容器内路径，实际数据保存在宿主机挂载目录
# DATA_ROOT=./data

# 日志级别: DEBUG / INFO / WARNING / ERROR
# Docker 部署建议设为 INFO，本地开发可设为 DEBUG
# LOG_LEVEL=INFO

# 单次上传最大大小（字节，默认 500MB）
# 超过此大小的文件上传将被拒绝
# MAX_UPLOAD_SIZE=524288000

# 服务端目录导入白名单（JSON 数组格式）
# 限制服务端目录导入功能允许导入的路径
# Docker 部署时，需将宿主机目录映射到容器内（通过 docker-compose.yml volumes）
# IMPORT_DIR_WHITELIST=["/docs","/import"]
